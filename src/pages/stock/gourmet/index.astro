---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const gourmet = await getCollection('gourmet');
const sorted = gourmet.sort((a, b) => {
  if (a.data.visitDate && b.data.visitDate) return b.data.visitDate.valueOf() - a.data.visitDate.valueOf();
  return 0;
});

---

<BaseLayout title="Gourmet | Yoshi.T" description="グルメ・飲食店">
  <div class="mb-6">
    <a href="/stock/" class="text-sm text-gray-500 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark">← Stock</a>
  </div>
  <h1 class="text-2xl font-bold mb-6">🍽️ Gourmet</h1>
  {sorted.length > 0 ? (
    <ul class="space-y-4">
      {sorted.map(item => (
        <li>
          <a href={`/stock/gourmet/${item.id}/`} class="group block border border-gray-200 dark:border-gray-800 rounded-lg p-4 hover:border-accent dark:hover:border-accent-dark transition-colors">
            <div class="font-medium group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
              {item.data.title}
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">
              {item.data.category}
              {item.data.area && ` · ${item.data.area}`}
            </div>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="text-gray-500 dark:text-gray-400">まだ登録がありません。</p>
  )}
</BaseLayout>
