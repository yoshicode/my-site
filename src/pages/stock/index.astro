---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const [books, sports] = await Promise.all([
  getCollection('books'),
  getCollection('sports'),
]);

const categories = [
  { href: '/stock/books/', label: 'Books', icon: '📚', description: '読んだ本', count: books.length },
  { href: '/stock/sports/', label: 'Sports', icon: '⚽', description: 'スポーツ', count: sports.length },
];
---

<BaseLayout title="Stock | Yoshi.T" description="ストック型コンテンツ一覧">
  <h1 class="text-2xl font-bold mb-2">Stock</h1>
  <p class="text-gray-600 dark:text-gray-400 mb-8">
    自分を構成するモノやコンテンツをカテゴリ別にまとめています。
  </p>
  <div class="grid gap-4">
    {categories.map(cat => (
      <a
        href={cat.href}
        class="flex items-center gap-4 border border-gray-200 dark:border-gray-800 rounded-lg p-5 hover:border-accent dark:hover:border-accent-dark transition-colors group"
      >
        <span class="text-3xl">{cat.icon}</span>
        <div class="flex-1">
          <div class="font-medium group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
            {cat.label}
          </div>
          <div class="text-sm text-gray-500 dark:text-gray-400">{cat.description}</div>
        </div>
        <span class="text-sm text-gray-400 dark:text-gray-500">{cat.count} items</span>
      </a>
    ))}
  </div>
</BaseLayout>
