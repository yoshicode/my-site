---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('books');
const sorted = books.sort((a, b) => b.data.readDate.valueOf() - a.data.readDate.valueOf());

---

<BaseLayout title="Books | Yoshi.T" description="読んだ本">
  <div class="mb-6">
    <a href="/stock/" class="text-sm text-gray-500 dark:text-gray-400 hover:text-accent dark:hover:text-accent-dark">← Stock</a>
  </div>
  <h1 class="text-2xl font-bold mb-6">📚 Books</h1>
  {sorted.length > 0 ? (
    <ul class="space-y-4">
      {sorted.map(book => (
        <li>
          <a href={`/stock/books/${book.id}/`} class="group block border border-gray-200 dark:border-gray-800 rounded-lg p-4 hover:border-accent dark:hover:border-accent-dark transition-colors">
            <div class="font-medium group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
              {book.data.title}
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">
              {book.data.author}
            </div>
          </a>
        </li>
      ))}
    </ul>
  ) : (
    <p class="text-gray-500 dark:text-gray-400">まだ登録がありません。</p>
  )}
</BaseLayout>
