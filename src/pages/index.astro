---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const [blog, books, sports, gourmet] = await Promise.all([
  getCollection('blog'),
  getCollection('books'),
  getCollection('sports'),
  getCollection('gourmet'),
]);

type RecentItem = {
  title: string;
  date: Date;
  href: string;
  category: string;
  icon: string;
};

const recentItems: RecentItem[] = [
  ...blog.map(p => ({
    title: p.data.title,
    date: p.data.pubDate,
    href: `/blog/${p.id}/`,
    category: 'Blog',
    icon: '📝',
  })),
  ...books.map(b => ({
    title: b.data.title,
    date: b.data.readDate,
    href: `/stock/books/${b.id}/`,
    category: 'Books',
    icon: '📚',
  })),
  ...sports.map(s => ({
    title: s.data.title,
    date: new Date(),
    href: `/stock/sports/${s.id}/`,
    category: 'Sports',
    icon: '⚽',
  })),
  ...gourmet.map(g => ({
    title: g.data.title,
    date: g.data.visitDate ?? new Date(),
    href: `/stock/gourmet/${g.id}/`,
    category: 'Gourmet',
    icon: '🍽️',
  })),
]
  .sort((a, b) => b.date.valueOf() - a.date.valueOf())
  .slice(0, 5);

const stockCategories = [
  { href: '/stock/books/', label: 'Books', icon: '📚', description: '読んだ本' },
  { href: '/stock/sports/', label: 'Sports', icon: '⚽', description: 'スポーツ' },
  { href: '/stock/gourmet/', label: 'Gourmet', icon: '🍽️', description: 'グルメ・飲食店' },
];

const formatDate = (date: Date) =>
  date.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Home | Yoshi.T">
  <section class="mb-12">
    <h1 class="text-2xl font-bold mb-2">Welcome</h1>
    <p class="text-gray-600 dark:text-gray-400">
      ブログとストック型コンテンツを通じて、自分の考えや好きなものを記録しています。
    </p>
  </section>

  <section class="mb-12">
    <h2 class="text-xl font-bold mb-4">Recent Posts</h2>
    {recentItems.length > 0 ? (
      <ul class="space-y-4">
        {recentItems.map(item => (
          <li>
            <a href={item.href} class="group block">
              <div class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
                <span>{item.icon}</span>
                <span>{item.category}</span>
                <span>·</span>
                <span>{formatDate(item.date)}</span>
              </div>
              <div class="font-medium group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
                {item.title}
              </div>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-gray-500 dark:text-gray-400 text-sm">まだ記事がありません。</p>
    )}
  </section>

  <section>
    <h2 class="text-xl font-bold mb-4">Stock</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {stockCategories.map(cat => (
        <a
          href={cat.href}
          class="border border-gray-200 dark:border-gray-800 rounded-lg p-4 hover:border-accent dark:hover:border-accent-dark transition-colors group"
        >
          <div class="text-2xl mb-2">{cat.icon}</div>
          <div class="font-medium text-sm group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
            {cat.label}
          </div>
          <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">{cat.description}</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
